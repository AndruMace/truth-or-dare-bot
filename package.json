{
  "name": "td-discord-bot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "start:prod": "bun run src/start.ts",
    "dev": "bun --watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "validate-prompts": "bun run src/data/prompts/validate.ts",
    "generate-prompt-bank": "bun run scripts/generate-prompt-bank.ts",
    "register-commands": "bun run src/scripts/register-commands.ts"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "drizzle-orm": "^0.44.2",
    "postgres": "^3.4.7",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3"
  }
}
